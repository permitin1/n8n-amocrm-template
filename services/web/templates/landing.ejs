<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Выгодное страхование — Консультация</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #f8f9fb;
      --card: #ffffff;
      --text: #1a1a2e;
      --text-secondary: #6b7280;
      --border: #e5e7eb;
      --accent: #6366f1;
      --tg: #2AABEE;
      --max: #7B5CFA;
      --max-end: #4ECDC4;
      --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
      --shadow-lg: 0 4px 16px rgba(0,0,0,0.08);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100dvh;
      display: flex; align-items: center; justify-content: center;
      padding: 24px 16px;
    }
    .container { width: 100%; max-width: 460px; text-align: center; }

    .author-row {
      display: inline-flex; align-items: center; gap: 10px;
      margin-bottom: 20px;
      opacity: 0; animation: fadeIn 0.5s ease forwards;
    }
    .author-photo {
      width: 40px; height: 40px; border-radius: 50%; object-fit: cover;
      object-position: 70% 10%;
    }
    .author-meta { text-align: left; }
    .author-name { font-size: 14px; font-weight: 600; color: var(--text); display: block; line-height: 1.2; }
    .author-role { font-size: 12px; color: var(--text-secondary); }

    h1 {
      font-size: 26px; font-weight: 700; line-height: 1.25;
      letter-spacing: -0.3px; margin-bottom: 16px;
      opacity: 0; animation: fadeIn 0.5s ease 0.05s forwards;
    }

    .services {
      display: flex; flex-wrap: wrap; gap: 8px; justify-content: center;
      margin-bottom: 10px;
      opacity: 0; animation: fadeIn 0.5s ease 0.1s forwards;
    }
    .services span {
      font-size: 13px; font-weight: 500; color: var(--text-secondary);
      background: var(--card); border: 1px solid var(--border); border-radius: 20px;
      padding: 6px 14px;
    }

    .trust {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 13px; color: var(--accent); font-weight: 500; margin-bottom: 28px;
      opacity: 0; animation: fadeIn 0.5s ease 0.12s forwards;
    }
    .trust svg { width: 14px; height: 14px; }

    .label {
      font-size: 13px; font-weight: 600; color: var(--text-secondary);
      text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 12px;
      opacity: 0; animation: fadeIn 0.5s ease 0.15s forwards;
    }

    .phone-wrap {
      margin-bottom: 20px;
      opacity: 0; animation: fadeIn 0.5s ease 0.18s forwards;
    }
    .phone-input {
      width: 100%; padding: 16px 20px;
      font-size: 20px; font-weight: 600; font-family: 'Inter', sans-serif;
      letter-spacing: 1px;
      border: 1px solid var(--border); border-radius: 14px;
      background: var(--card); color: var(--text);
      text-align: center; outline: none; box-shadow: var(--shadow);
      transition: all 0.2s ease;
    }
    .phone-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(99,102,241,0.12); }
    .phone-input::placeholder { color: #c5c8d0; font-size: 16px; letter-spacing: 0; font-weight: 400; }

    .buttons-wrap {
      display: flex; flex-direction: column; gap: 12px;
      opacity: 0; animation: fadeIn 0.5s ease 0.22s forwards;
    }
    .messenger-btn {
      display: flex; align-items: center; gap: 16px;
      width: 100%; padding: 16px 20px;
      background: var(--card); border: 1px solid var(--border); border-radius: 16px;
      box-shadow: var(--shadow);
      font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 600;
      color: var(--text); text-decoration: none; cursor: pointer;
      transition: all 0.2s ease;
    }
    .messenger-btn:hover:not(.disabled) { box-shadow: var(--shadow-lg); transform: translateY(-1px); }
    .messenger-btn:active:not(.disabled) { transform: scale(0.99); }
    .messenger-btn.disabled { opacity: 0.4; pointer-events: none; }
    .messenger-btn .icon {
      width: 44px; height: 44px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .messenger-btn .icon svg { width: 24px; height: 24px; }
    .btn-tg .icon { background: var(--tg); }
    .btn-max .icon { background: linear-gradient(135deg, var(--max), var(--max-end)); }
    .messenger-btn .meta { text-align: left; }
    .messenger-btn .meta span:first-child { display: block; }
    .messenger-btn .meta .hint { display: block; font-size: 12px; color: var(--text-secondary); font-weight: 400; margin-top: 2px; }

    /* Desktop: "Далее" */
    .next-btn {
      display: none; width: 100%; padding: 16px 24px;
      border-radius: 14px; border: none;
      background: var(--accent); color: #fff;
      font-size: 15px; font-weight: 600; font-family: 'Inter', sans-serif;
      cursor: pointer; box-shadow: var(--shadow);
      transition: all 0.2s ease;
      opacity: 0; animation: fadeIn 0.5s ease 0.22s forwards;
    }
    .next-btn:hover:not(:disabled) { box-shadow: var(--shadow-lg); transform: translateY(-1px); }
    .next-btn:active:not(:disabled) { transform: scale(0.99); }
    .next-btn:disabled { opacity: 0.35; cursor: default; }
    .back-btn {
      display: none; background: none; border: none; color: var(--text-secondary);
      font-size: 13px; font-family: 'Inter', sans-serif; cursor: pointer;
      margin-top: 16px; transition: color 0.2s;
    }
    .back-btn:hover { color: var(--accent); }

    .qr-section { display: none; }
    @media (hover: hover) and (pointer: fine) {
      .buttons-wrap { display: none; }
      .next-btn { display: block; }
      .desktop-label-messenger { display: none; }
      .step-phone.hidden { display: none; }
      .qr-section {
        display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
        opacity: 0; animation: fadeIn 0.4s ease forwards;
      }
      .qr-section:not(.active) { display: none; }
      .qr-section.active { display: grid; }
      .back-btn.active { display: inline-block; }
      .qr-card {
        background: var(--card); border: 1px solid var(--border); border-radius: 20px;
        padding: 24px 16px 20px; box-shadow: var(--shadow);
        display: flex; flex-direction: column; align-items: center; gap: 14px;
        transition: all 0.25s ease;
      }
      .qr-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-2px); }
      .qr-wrap {
        position: relative; width: 180px;
        background: var(--bg); border-radius: 14px; padding: 12px 12px 46px;
      }
      .qr-wrap canvas { width: 100%; height: auto; display: block; border-radius: 6px; }
      .qr-card-label {
        position: absolute; bottom: 12px; left: 0; right: 0;
        font-size: 14px; font-weight: 700; text-align: center;
      }
      .qr-card.tg .qr-card-label { color: var(--tg); }
      .qr-card.max .qr-card-label { color: var(--max); }
      .qr-logo {
        position: absolute; top: calc(50% - 20px); left: 50%; transform: translate(-50%, -50%);
        width: 48px; height: 48px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 0 0 4px var(--bg);
      }
      .qr-logo svg { width: 24px; height: 24px; }
      .qr-logo.tg { background: var(--tg); }
      .qr-logo.max { background: linear-gradient(135deg, var(--max), var(--max-end)); }
      .qr-link { font-size: 12px; }
      .qr-link a { color: var(--text-secondary); text-decoration: none; border-bottom: 1px dashed var(--border); transition: color 0.2s; }
      .qr-card.tg .qr-link a:hover { color: var(--tg); }
      .qr-card.max .qr-link a:hover { color: var(--max); }
    }

    .footer {
      margin-top: 24px; font-size: 12px; color: var(--text-secondary); line-height: 1.5;
      opacity: 0; animation: fadeIn 0.5s ease 0.3s forwards;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="author-row">
      <img class="author-photo" src="/public/img/author.png" alt="Дарья Швецова">
      <div class="author-meta">
        <span class="author-name">Дарья Швецова</span>
        <span class="author-role">Эксперт по страхованию</span>
      </div>
    </div>

    <h1>Сэкономим на страховке до 70%</h1>

    <div class="services">
      <span>Ипотечное страхование</span>
      <span>Потреб. кредиты</span>
      <span>Возврат навязанных страховок</span>
      <span>Все виды страхования</span>
    </div>

    <p class="trust">
      <svg viewBox="0 0 16 16" fill="none"><path d="M8 1l2.245 4.55 5.022.73-3.633 3.541.858 5.003L8 12.675l-4.492 2.36.858-5.003L.733 6.49l5.022-.73L8 1z" fill="currentColor"/></svg>
      Более 3 000 семей уже сэкономили
    </p>

    <div id="step-phone" class="step-phone">
      <p class="label">Ваш номер телефона</p>
      <div class="phone-wrap">
        <input class="phone-input" id="phone" type="tel" placeholder="Введите номер" inputmode="tel" autocomplete="tel">
      </div>
      <button class="next-btn" id="next-btn" disabled>Далее</button>
      <p class="label desktop-label-messenger" style="animation-delay:0.25s">Выберите мессенджер</p>
    </div>

    <!-- Mobile -->
    <div class="buttons-wrap">
      <a class="messenger-btn btn-tg disabled" id="btn-tg" href="#">
        <div class="icon"><svg viewBox="0 0 24 24" fill="none"><path d="M20.665 3.717l-17.73 6.837c-1.21.486-1.203 1.161-.222 1.462l4.552 1.42 10.532-6.645c.498-.303.953-.14.579.192l-8.533 7.701h-.002l.002.001-.314 4.692c.46 0 .663-.211.921-.46l2.211-2.15 4.599 3.397c.848.467 1.457.227 1.668-.785L21.933 5.054c.311-1.238-.472-1.8-1.268-1.337z" fill="#fff"/></svg></div>
        <div class="meta"><span>Telegram</span><span class="hint">Откроется приложение</span></div>
      </a>
      <a class="messenger-btn btn-max disabled" id="btn-max" href="#">
        <div class="icon"><svg viewBox="0 0 44 44" fill="none"><path d="M22.47 41.88c-4.11 0-6.02-.6-9.34-3-2.1 2.7-8.75 4.81-9.04 1.2 0-2.71-.6-5-1.28-7.5C2 29.5 1.08 26.07 1.08 21.1 1.08 9.23 9.82.3 21.36.3c11.55 0 20.6 9.37 20.6 20.91a20.6 20.6 0 0 1-20.49 20.67zm.17-31.32c-5.62-.29-10 3.6-10.97 9.7-.8 5.05.62 11.2 1.83 11.52.58.14 2.04-1.04 2.95-1.95a10.4 10.4 0 0 0 5.08 1.81 10.7 10.7 0 0 0 11.19-9.97 10.7 10.7 0 0 0-10.08-11.1z" fill="#fff"/></svg></div>
        <div class="meta"><span>MAX</span><span class="hint">Откроется приложение</span></div>
      </a>
    </div>

    <!-- Desktop QR -->
    <div class="qr-section" id="qr-section">
      <div class="qr-card tg">
        <div class="qr-wrap">
          <canvas id="qr-tg"></canvas>
          <div class="qr-logo tg"><svg viewBox="0 0 24 24" fill="none"><path d="M20.665 3.717l-17.73 6.837c-1.21.486-1.203 1.161-.222 1.462l4.552 1.42 10.532-6.645c.498-.303.953-.14.579.192l-8.533 7.701h-.002l.002.001-.314 4.692c.46 0 .663-.211.921-.46l2.211-2.15 4.599 3.397c.848.467 1.457.227 1.668-.785L21.933 5.054c.311-1.238-.472-1.8-1.268-1.337z" fill="#fff"/></svg></div>
          <span class="qr-card-label">Telegram</span>
        </div>
        <span class="qr-link"><a id="link-tg" href="#">Открыть ссылку</a></span>
      </div>
      <div class="qr-card max">
        <div class="qr-wrap">
          <canvas id="qr-max"></canvas>
          <div class="qr-logo max"><svg viewBox="0 0 44 44" fill="none"><path d="M22.47 41.88c-4.11 0-6.02-.6-9.34-3-2.1 2.7-8.75 4.81-9.04 1.2 0-2.71-.6-5-1.28-7.5C2 29.5 1.08 26.07 1.08 21.1 1.08 9.23 9.82.3 21.36.3c11.55 0 20.6 9.37 20.6 20.91a20.6 20.6 0 0 1-20.49 20.67zm.17-31.32c-5.62-.29-10 3.6-10.97 9.7-.8 5.05.62 11.2 1.83 11.52.58.14 2.04-1.04 2.95-1.95a10.4 10.4 0 0 0 5.08 1.81 10.7 10.7 0 0 0 11.19-9.97 10.7 10.7 0 0 0-10.08-11.1z" fill="#fff"/></svg></div>
          <span class="qr-card-label">MAX</span>
        </div>
        <span class="qr-link"><a id="link-max" href="#">Открыть ссылку</a></span>
      </div>
    </div>
    <button class="back-btn" id="back-btn">&#8592; Изменить номер</button>

    <p class="footer">Работаем по всей России. Законно и официально.</p>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/qrious@4.0.2/dist/qrious.min.js"></script>
  <script>
    var TG_BOT = '<%= tgBot %>';
    var MAX_BOT = '<%= maxBot %>';
    var utmSource = '<%= typeof utm_source !== "undefined" ? utm_source : "" %>';
    var utmMedium = '<%= typeof utm_medium !== "undefined" ? utm_medium : "" %>';
    var utmCampaign = '<%= typeof utm_campaign !== "undefined" ? utm_campaign : "" %>';
    var utmTerm = '<%= typeof utm_term !== "undefined" ? utm_term : "" %>';
    var utmContent = '<%= typeof utm_content !== "undefined" ? utm_content : "" %>';

    var phoneInput = document.getElementById('phone');
    var btnTg = document.getElementById('btn-tg');
    var btnMax = document.getElementById('btn-max');
    var qrSection = document.getElementById('qr-section');
    var nextBtn = document.getElementById('next-btn');
    var backBtn = document.getElementById('back-btn');
    var stepPhone = document.getElementById('step-phone');
    var isDesktop = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    var currentPhone = '';

    phoneInput.addEventListener('input', function() {
      var digits = this.value.replace(/\D/g, '');
      if (digits.length > 0 && digits[0] === '8') digits = '7' + digits.slice(1);
      if (digits.length > 11) digits = digits.slice(0, 11);
      if (digits.length === 0) { this.value = ''; currentPhone = ''; updateState(); return; }
      var f = '+7';
      if (digits.length > 1) f += ' (' + digits.slice(1, 4);
      if (digits.length > 4) f += ') ' + digits.slice(4, 7);
      if (digits.length > 7) f += '-' + digits.slice(7, 9);
      if (digits.length > 9) f += '-' + digits.slice(9, 11);
      this.value = f;
      currentPhone = digits.length === 11 ? digits : '';
      updateState();
    });

    phoneInput.addEventListener('focus', function() { if (!this.value) this.value = '+7'; });
    phoneInput.addEventListener('blur', function() { if (this.value === '+7') this.value = ''; });

    function updateState() {
      var valid = !!currentPhone;
      btnTg.classList.toggle('disabled', !valid); btnTg.href = valid ? buildUrl('tg') : '#';
      btnMax.classList.toggle('disabled', !valid); btnMax.href = valid ? buildUrl('max') : '#';
      if (nextBtn) nextBtn.disabled = !valid;
    }

    function buildPayload(phone, sep) {
      var parts = ['tel' + phone];
      var utms = [utmSource, utmMedium, utmCampaign, utmTerm, utmContent];
      if (utms.some(function(u) { return !!u; })) {
        for (var i = 0; i < utms.length; i++) parts.push(utms[i] || '');
        while (parts.length > 1 && parts[parts.length - 1] === '') parts.pop();
      }
      return parts.join(sep);
    }

    function buildUrl(type) {
      if (!currentPhone) return '#';
      if (type === 'tg') return 'https://t.me/' + TG_BOT + '?start=' + buildPayload(currentPhone, '-');
      return 'https://max.ru/' + MAX_BOT + '?start=' + buildPayload(currentPhone, '_');
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function() {
        if (!currentPhone) return;
        var tgUrl = buildUrl('tg'), maxUrl = buildUrl('max');
        stepPhone.classList.add('hidden');
        qrSection.classList.add('active');
        backBtn.classList.add('active');
        document.getElementById('link-tg').href = tgUrl;
        document.getElementById('link-max').href = maxUrl;
        new QRious({ element: document.getElementById('qr-tg'), value: tgUrl, size: 400, level: 'H', foreground: '#2AABEE', background: '#f8f9fb' });
        new QRious({ element: document.getElementById('qr-max'), value: maxUrl, size: 400, level: 'H', foreground: '#7B5CFA', background: '#f8f9fb' });
      });
    }

    if (backBtn) {
      backBtn.addEventListener('click', function() {
        stepPhone.classList.remove('hidden');
        qrSection.classList.remove('active');
        backBtn.classList.remove('active');
        phoneInput.focus();
      });
    }
  </script>
</body>
</html>
